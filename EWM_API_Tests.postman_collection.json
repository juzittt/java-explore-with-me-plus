                  "});",
                  "pm.test('Name updated', function() {",
                  "    pm.expect(pm.response.json().name).to.eql('Музыка');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Музыка\"\n}"
            },
            "url": "{{baseUrl}}/admin/categories/{{categoryId}}"
          }
        },
        {
          "name": "Update category (duplicate name - 409)",
