    {
      "name": "3. Events - Private",
      "item": [
        {
          "name": "Create event (success)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 201', function() {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "pm.test('Event created with correct state', function() {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json.state).to.eql('PENDING');",
                  "    pm.expect(json.title).to.eql('Концерт рок-группы');",
                  "    pm.expect(json.views).to.eql(0);",
                  "    pm.expect(json.confirmedRequests).to.eql(0);",
                  "    pm.collectionVariables.set('eventId', json.id);",
                  "});"
                ]
              }
            },
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "// Дата через 3 часа от текущего момента",
                  "const date = new Date();",
                  "date.setHours(date.getHours() + 3);",
                  "const pad = n => n.toString().padStart(2, '0');",
                  "const formatted = `${date.getFullYear()}-${pad(date.getMonth()+1)}-${pad(date.getDate())} ${pad(date.getHours())}:${pad(date.getMinutes())}:${pad(date.getSeconds())}`;",
                  "pm.variables.set('futureDate', formatted);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"annotation\": \"Отличный концерт любимой группы\",\n  \"category\": {{categoryId}},\n  \"description\": \"Приходите на концерт рок-группы. Будет весело!\",\n  \"eventDate\": \"{{futureDate}}\",\n  \"location\": {\n    \"lat\": 55.75,\n    \"lon\": 37.61\n  },\n  \"paid\": true,\n  \"participantLimit\": 100,\n  \"requestModeration\": true,\n  \"title\": \"Концерт рок-группы\"\n}"
            },
            "url": "{{baseUrl}}/users/{{userId}}/events"
          }
        },
        {
          "name": "Create event (past date - 409)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 409', function() {",
                  "    pm.response.to.have.status(409);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"annotation\": \"Прошедшее событие\",\n  \"category\": {{categoryId}},\n  \"description\": \"Это событие уже прошло\",\n  \"eventDate\": \"2020-01-01 10:00:00\",\n  \"location\": {\n    \"lat\": 55.75,\n    \"lon\": 37.61\n  },\n  \"title\": \"Прошедшее событие\"\n}"
            },
            "url": "{{baseUrl}}/users/{{userId}}/events"
          }
        },
        {
          "name": "Get user events",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', function() {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "pm.test('Response is array', function() {",
                  "    pm.expect(pm.response.json()).to.be.an('array');",
                  "    pm.expect(pm.response.json().length).to.be.at.least(1);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/users/{{userId}}/events?from=0&size=10",
              "host": ["{{baseUrl}}"],
              "path": ["users", "{{userId}}", "events"],
              "query": [
                { "key": "from", "value": "0" },
                { "key": "size", "value": "10" }
              ]
            }
          }
        },
        {
          "name": "Get user event by id",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', function() {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "pm.test('Event belongs to user', function() {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json.initiator.id).to.eql(parseInt(pm.collectionVariables.get('userId')));",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/users/{{userId}}/events/{{eventId}}"
          }
        },
        {
          "name": "Update event (change title)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', function() {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "pm.test('Title updated', function() {",
                  "    pm.expect(pm.response.json().title).to.eql('Новый концерт');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Новый концерт\"\n}"
            },
            "url": "{{baseUrl}}/users/{{userId}}/events/{{eventId}}"
          }
        },
        {
          "name": "Update event (send to review)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', function() {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "pm.test('State is PENDING', function() {",
                  "    pm.expect(pm.response.json().state).to.eql('PENDING');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"stateAction\": \"SEND_TO_REVIEW\"\n}"
            },
            "url": "{{baseUrl}}/users/{{userId}}/events/{{eventId}}"
          }
        },
        {
          "name": "Update non-existent event (404)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 404', function() {",
                  "    pm.response.to.have.status(404);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Test\"\n}"
            },
            "url": "{{baseUrl}}/users/{{userId}}/events/999999"
          }
        }
      ]
